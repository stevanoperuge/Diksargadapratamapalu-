    <script>
        let currentIndex = 0;
        const slides = document.getElementById('slide-track');
        const slideItems = document.querySelectorAll('.slide');
        const dotsContainer = document.getElementById('dots-container');

        slideItems.forEach((_, i) => {
            const dot = document.createElement('span');
            dot.classList.add('dot');
            if (i === 0) dot.classList.add('active');
            dotsContainer.appendChild(dot);
        });

        const dots = document.querySelectorAll('.dot');
        function updateSlide() {
            slides.style.transform = `translateX(-${currentIndex * 100}%)`;
            dots.forEach(dot => dot.classList.remove('active'));
            dots[currentIndex].classList.add('active');
        }

        setInterval(() => {
            currentIndex = (currentIndex + 1) % slideItems.length;
            updateSlide();
        }, 3500);

        function kirimWA() {
            const fields = {
                Nama: document.getElementById('reg_nama').value,
                TTL: document.getElementById('reg_ttl').value,
                Alamat: document.getElementById('reg_alamat').value,
                Fisik: document.getElementById('reg_tinggi').value,
                NIK: document.getElementById('reg_nik').value,
                HP: document.getElementById('reg_kontak').value
            };

            if(!fields.Nama || !fields.HP) return alert("Mohon lengkapi Nama dan No. HP!");

            let msg = `Halo Admin Pelatihan Satpam Sulteng,%0A%0ASaya ingin mendaftar Gada Pratama:%0A%0A`;
            for (const [key, val] of Object.entries(fields)) msg += `*${key}:* ${val}%0A`;

            window.open("https://wa.me/message/KXMNWIUR75S3C1?text=" + msg, '_blank');
        }
    </script>
